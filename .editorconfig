ij_java_resources_new_line_after_left_paren = false
ij_java_resources_new_line_before_right_paren = false
ij_java_keep_simple_getters_setters_in_one_line = false
ij_java_if_statement_brace_force = never
ij_java_while_statement_brace_force = never
ij_java_for_statement_brace_force = never
ij_java_do_while_statement_brace_force = never
ij_java_switch_statement_brace_force = never
